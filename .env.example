# ============================================================
# MegaCNC Environment Configuration
# Copy this file to .env and adjust values for your setup.
# ============================================================

# Django
SECRET_KEY=django-insecure-dp#h4@*pio(2yfpeuu-f7va!^92c#fy&wif+goo&^g(bzy5d9b
DEBUG=True
# Use * for LAN access to the desktop bundle (Waitress on 0.0.0.0). Restrict in production.
ALLOWED_HOSTS=*

# Database — choose one:
#   postgresql  (default, needs PostgreSQL installed)
#   sqlite3     (zero-config, great for local dev/debug)
DB_ENGINE=sqlite3

# PostgreSQL settings (ignored when DB_ENGINE=sqlite3)
DB_NAME=mcccnc
DB_USER=postgres
DB_PASSWORD=MccAdmin
DB_HOST=localhost
DB_PORT=5432

# Celery / Redis
# Set CELERY_EAGER=True to run all tasks inline (no Redis or Celery worker needed).
# Perfect for debugging in PyCharm — tasks execute in the Django process.
CELERY_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
